        <mxCell id="p1-stage3" value="3. R1-R10 Mapping&lt;br&gt;&lt;font style=&quot;font-size: 13px&quot;&gt;直接映射、领域模式、指纹去重&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#DCFCE7;strokeColor=#16A34A;fontColor=#14532D;fontSize=15;fontStyle=1;spacing=10;" vertex="1" parent="1">
